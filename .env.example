# ============================================================
# LLM API 配置（必填）
# ============================================================
# MiniMax（当前主力模型）
MINIMAX_API_KEY=your-minimax-key
MINIMAX_GROUP_ID=your-group-id

# OpenAI（可选备用）
OPENAI_API_KEY=sk-xxx

# ============================================================
# 搜索 API 配置
# ============================================================
# Tavily AI Search（主力搜索，强烈推荐）
# 申请免费 Key：https://tavily.com
TAVILY_API_KEY=tvly-xxx

# 注意：DuckDuckGo 为自动备用搜索引擎，无需 API Key

# ============================================================
# Reddit API 配置（话题发现功能所需）
# 申请地址：https://www.reddit.com/prefs/apps
# ============================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=war3-wiki-bot/1.0 by your-reddit-username

# ============================================================
# Agent 编排配置
# ============================================================
# 文章生成使用的模型
AGENT_LLM_MODEL=minimax/abab7-chat-preview

# 并发处理主题数（防止 API 限速）
AGENT_CONCURRENCY=3

# 质量审核最低分（低于此分触发重写）
AGENT_QUALITY_THRESHOLD=0.7

# Reviewer 最大重写循环次数
AGENT_MAX_REVIEW_LOOPS=2

# ============================================================
# 管道配置
# ============================================================
MAX_RETRY_COUNT=3
RETRY_WAIT_SECONDS=60
MAX_TOPICS_PER_RUN=10
DOCS_OUTPUT_DIR=docs
