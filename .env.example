# ============================================================
# LLM API 配置（至少选择一个）
# ============================================================
# OpenAI（推荐，用于 article_gen_lm / article_polish_lm）
OPENAI_API_KEY=sk-xxx

# Anthropic Claude（备选强力模型）
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================
# 搜索 API 配置
# ============================================================
# Tavily AI Search（付费，质量最佳，推荐）
TAVILY_API_KEY=tvly-xxx

# Bing Search（付费，备选）
BING_SEARCH_API_KEY=xxx

# 注意：DuckDuckGo 为默认免费搜索引擎，无需 API Key

# ============================================================
# 搜索引擎选择：duckduckgo / tavily / bing（默认：duckduckgo）
# ============================================================
SEARCH_ENGINE=duckduckgo

# ============================================================
# LLM 模型配置
# ============================================================
# 轻量模型（用于高频对话研究，成本低）
CONV_SIMULATOR_MODEL=gpt-3.5-turbo
QUESTION_ASKER_MODEL=gpt-3.5-turbo

# 强力模型（用于文章生成，质量高）
OUTLINE_GEN_MODEL=gpt-4o
ARTICLE_GEN_MODEL=gpt-4o
ARTICLE_POLISH_MODEL=gpt-4o

# ============================================================
# 管道配置
# ============================================================
# 最大重试次数
MAX_RETRY_COUNT=3

# 重试等待时间（秒）
RETRY_WAIT_SECONDS=60

# 每次运行最多处理主题数（-1 表示全部）
MAX_TOPICS_PER_RUN=10

# 输出文章目录（相对于仓库根目录）
DOCS_OUTPUT_DIR=docs
